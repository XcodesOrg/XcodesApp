    "When making an Xcode version Active/Selected, try and create a symbolic link named Xcode.app in the installation directory" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند جعل إصدار Xcode نشطًا/محددًا، حاول إنشاء رابط رمزي باسم Xcode.app في دليل التثبيت"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
