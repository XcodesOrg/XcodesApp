    "Alert.Uninstall.Message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم نقله إلى سلة المهملات، ولكن لن يتم إفراغه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es mourà a la paperera, però no es buidarà."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Anwendung wird in den Papierkorb verschoben, dieser wird aber nicht geleert."
