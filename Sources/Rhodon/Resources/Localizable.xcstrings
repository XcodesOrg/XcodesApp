          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "휴지통으로 이동되지만 비워지지는 않습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het zal worden verplaatst naar de Prullenbak, maar deze zal niet geleegd worden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
